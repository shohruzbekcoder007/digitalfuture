# --- Server ---
PORT=5000
NODE_ENV=development

# --- Database ---
# Mahalliy MongoDB (default):
MONGO_URI=mongodb://127.0.0.1:27017/journal_db
# Yoki MongoDB Atlas:
# MONGO_URI=mongodb+srv://USER:PASS@cluster0.example.mongodb.net/journal_db?retryWrites=true&w=majority

# --- Auth ---
JWT_SECRET=change_me_in_production_super_secret_key
JWT_EXPIRES_IN=7d

# --- Server bind ---
# 0.0.0.0 = LAN'dagi boshqa qurilmalar ham kira oladi.
# Faqat shu kompyuterdan kirish kerak bo'lsa: HOST=127.0.0.1
HOST=0.0.0.0

# --- Frontend origin (CORS) ---
# Development'da bo'sh qoldirsangiz, LAN ichidagi (10.x, 172.16-31.x, 192.168.x) va localhost origin'lari avtomatik ruxsat etiladi.
# Production uchun vergul bilan ajratilgan ro'yxat:
# CLIENT_URL=https://journal.example.com,https://www.journal.example.com
CLIENT_URL=http://localhost:5173

# --- File uploads ---
# Cloudinary kalitlari bo'sh qoldirilsa, fayllar avtomatik
# backend/uploads/ papkasiga lokal saqlanadi va
# http://localhost:5000/uploads/... orqali xizmat qilinadi.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
